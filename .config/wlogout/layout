{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "hyprshutdown",
    "text" : "Log Out",
    "keybind" : "e"
}
{
    "label" : "reboot",
    "action" : "hyprshutdown --post-cmd 'reboot'",
    "text" : "Restart",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "hyprshutdown --post-cmd 'shutdown -P 0'",
    "text" : "Power Off",
    "keybind" : "s"
}
